{
  "manifest_version": 3,
  "name": "Synapse AI Link",
  "version": "1.0",
  "description": "Cross-LLM context bridge. Instantly link and continue conversations across ChatGPT, Claude, Gemini, and Perplexity.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://*.firebaseapp.com/*",
    "https://*.identitytoolkit.googleapis.com/*",
    "https://*.firestore.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.min.js", "libs/pdf.worker.min.js", "libs/mammoth.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}